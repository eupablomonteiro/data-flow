{
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "build:web": {
      "outputs": [".next/**"]
    },
    "build:node": {
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}
