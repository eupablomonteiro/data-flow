generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Sale {
  id       String   @id @default(uuid())
  date     DateTime
  product  String
  category String
  price    Float
  quantity Int
  country  String
  total    Float

  uploadId String?
  upload   Upload? @relation(fields: [uploadId], references: [id])

  createdAt DateTime @default(now())

  @@index([date])
  @@index([product])
  @@index([category])
  @@index([country])
}

model Upload {
  id       String       @id @default(uuid())
  filename String
  filepath String
  status   UploadStatus @default(PENDING)

  totalRows     Int?
  processedRows Int?
  successRows   Int?
  errorRows     Int?

  startedAt   DateTime?
  processedAt DateTime?

  createdAt DateTime @default(now())
  sales     Sale[]
}
