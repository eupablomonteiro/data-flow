{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@dataflow/config": [
        "../../packages/config/src/index.ts"
      ],
      "@dataflow/config/*": [
        "../../packages/config/src/*"
      ],
      "@dataflow/database": [
        "../../packages/database/src/index.ts"
      ],
      "@dataflow/database/client": [
        "../../packages/database/src/client.ts"
      ],
      "@dataflow/database/*": [
        "../../packages/database/src/*"
      ],
      "@dataflow/logger": [
        "../../packages/logger/src/index.ts"
      ],
      "@dataflow/logger/*": [
        "../../packages/logger/src/*"
      ],
      "@dataflow/queue": [
        "../../packages/queue/src/index.ts"
      ],
      "@dataflow/queue/*": [
        "../../packages/queue/src/*"
      ],
      "@dataflow/types": [
        "../../packages/types/src/index.ts"
      ],
      "@dataflow/types/*": [
        "../../packages/types/src/*"
      ],
      "@dataflow/validation": [
        "../../packages/validation/src/index.ts"
      ],
      "@dataflow/validation/*": [
        "../../packages/validation/src/*"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next.config.mjs"
  ],
  "exclude": [
    "node_modules"
  ]
}
